{
	"name": "openscp",
	"version": "0.1.0",
	"description": "A modular WinSCP replacement with dual-pane file manager",
	"keywords": [],
	"license": "MIT",
	"author": "",
	"type": "module",
	"main": "./out/main/index.js",
	"scripts": {
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "eslint . --config eslint.config.ts --cache --cache-strategy content ",
		"lint:fix": "eslint . --config eslint.config.ts --cache --cache-strategy content --fix ",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
		"test:all": "pnpm run test && pnpm run test:integration",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:integration:watch": "vitest --config vitest.integration.config.ts",
		"check": "pnpm run fmt:check && pnpm run lint --quiet && pnpm run typecheck && pnpm run test --silent && pnpm run build "
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1063.0",
		"@base-ui/react": "1.5.0",
		"@fontsource-variable/inter": "5.2.8",
		"@fontsource/jetbrains-mono": "5.2.8",
		"@tailwindcss/vite": "4.3.0",
		"@tanstack/react-form": "1.32.1",
		"@xterm/addon-fit": "0.11.0",
		"@xterm/xterm": "6.0.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"date-fns": "4.4.0",
		"electron": "42.2.0",
		"electron-vite": "5.0.0",
		"embla-carousel-react": "8.6.0",
		"input-otp": "1.4.2",
		"lucide-react": "1.17.0",
		"next-themes": "0.4.6",
		"node-pty": "1.1.0",
		"pino": "10.3.1",
		"react": "19.2.7",
		"react-day-picker": "10.0.1",
		"react-dom": "19.2.7",
		"react-icons": "5.6.0",
		"react-resizable-panels": "4.11.2",
		"recharts": "3.8.1",
		"shadcn": "4.10.0",
		"sonner": "2.0.7",
		"ssh2": "1.17.0",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.0",
		"tw-animate-css": "1.4.0",
		"vaul": "1.1.2",
		"zod": "4.4.3",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@dword-design/eslint-plugin-import-alias": "8.1.8",
		"@electron/rebuild": "4.0.4",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.60.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/node": "25.9.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/sql.js": "1.4.11",
		"@types/ssh2": "1.15.5",
		"@vitejs/plugin-react": "4.7.0",
		"@vitest/coverage-v8": "4.1.8",
		"eslint": "10.4.1",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"globals": "17.6.0",
		"jsdom": "29.1.1",
		"oxfmt": "0.53.0",
		"pino-pretty": "13.1.3",
		"testcontainers": "12.0.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"vite": "6.4.3",
		"vitest": "4.1.8"
	}
}
