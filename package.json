{
	"name": "openscp",
	"version": "0.1.0",
	"type": "module",
	"description": "A modular WinSCP replacement with dual-pane file manager",
	"main": "./out/main/index.js",
	"scripts": {
		"lint": "eslint . --config eslint.config.ts ",
		"lint:fix": "eslint . --config eslint.config.ts  --fix",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
		"test:all": "pnpm run test && pnpm run test:integration",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:integration:watch": "vitest --config vitest.integration.config.ts",
		"check": "pnpm run lint --quiet && pnpm run typecheck && pnpm run test --run 2>&1 | tail -10 && pnpm run build "
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1053.0",
		"@base-ui/react": "^1.5.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/react-form": "^1.32.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.3.0",
		"electron": "^42.2.0",
		"electron-vite": "^5.0.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.16.0",
		"next-themes": "^0.4.6",
		"node-pty": "^1.1.0",
		"pino": "^10.3.1",
		"react": "^19.2.6",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.6",
		"react-icons": "^5.6.0",
		"react-resizable-panels": "^4.11.2",
		"recharts": "3.8.0",
		"shadcn": "^4.8.1",
		"sonner": "^2.0.7",
		"sql.js": "^1.14.1",
		"ssh2": "^1.17.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@dword-design/eslint-plugin-import-alias": "^8.1.8",
