{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"lib": ["ES2022"],
		"types": ["node"],
		"paths": {
			"@main/*": ["./src/main/*"],
			"@shared/*": ["./src/shared/*"],
			"@i18n/*": ["./src/i18n/*"]
		}
	},
	"include": [
		"src/main/**/*.d.ts",
		"src/main/**/*.ts",
		"src/preload/**/*.ts",
		"src/preload/**/*.d.ts",
		"src/shared/**/*.ts",
		"src/i18n/**/*.ts",
		"src/i18n/**/*.json",
		"electron.vite.config.ts",
		"vitest.integration.config.ts",
		"tests/integration/**/*.ts"
	],
	"exclude": ["tests/integration/**/*.spec.ts"]
}
