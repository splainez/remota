# ── Test Mode ──────────────────────────────────────────────────────────
# Set to "true" to use pre-existing external servers instead of Docker
TEST_USE_EXTERNAL=false

# ── SFTP (atmoz/sftp container) ───────────────────────────────────────
TEST_SFTP_HOST=localhost
TEST_SFTP_PORT=2222
TEST_SFTP_USER=testuser
TEST_SFTP_PASS=testpass
# TEST_SFTP_KEY_PATH=/path/to/test_key

# ── SCP (reuses SSH/SFTP server) ──────────────────────────────────────
TEST_SCP_HOST=localhost
TEST_SCP_PORT=2222
TEST_SCP_USER=testuser
TEST_SCP_PASS=testpass

# ── FTP (fauria/vsftpd container) ─────────────────────────────────────
TEST_FTP_HOST=localhost
TEST_FTP_PORT=21
TEST_FTP_USER=testuser
TEST_FTP_PASS=testpass

# ── S3 (minio/minio container) ────────────────────────────────────────
TEST_S3_ENDPOINT=http://localhost:9000
TEST_S3_PORT=9000
TEST_S3_ACCESS_KEY=minioadmin
TEST_S3_SECRET_KEY=minioadmin
TEST_S3_BUCKET=test-bucket
TEST_S3_REGION=us-east-1

# ── Docker ────────────────────────────────────────────────────────────
# Set a remote Docker host if not using the local daemon
# TEST_DOCKER_HOST=tcp://192.168.1.100:2375
