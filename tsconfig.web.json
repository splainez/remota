{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"paths": {
			"@renderer/*": ["./src/renderer/*"],
			"@shared/*": ["./src/shared/*"],
			"@i18n/*": ["./src/i18n/*"]
		}
	},
	"include": [
		"src/renderer/**/*.ts",
		"src/renderer/**/*.tsx",
		"src/renderer/**/*.css",
		"src/preload/**/*.d.ts",
		"src/shared/**/*.ts",
		"src/i18n/**/*.ts",
		"src/i18n/**/*.json"
	]
}
