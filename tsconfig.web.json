{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.css",
    "src/preload/**/*.d.ts",
    "src/shared/**/*.ts",
    "src/i18n/**/*.ts",
    "src/i18n/**/*.json"
  ]
}
