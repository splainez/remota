{
	"$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
	"appId": "com.remota.app",
	"productName": "Remota",
	"directories": {
		"output": "release"
	},
	"icon": "src/main/assets/icon",
	"npmRebuild": false,
	"files": [
		{
			"from": "out",
			"to": "/**/*"
		},
		"!**/*.test.*",
		"!**/*.test.ts",
		"!**/*.test.tsx",
		"!**/*.spec.*",
		"!**/*.spec.ts",
		"!**/*.spec.tsx"
	],
	"asar": true,
	"win": {
		"target": [
			{
				"target": "portable",
				"arch": ["x64"]
			}
		],
		"executableName": "Remota",
		"icon": "src/main/assets/icon.ico"
	},
	"mac": {
		"icon": "src/main/assets/icon.icns",
		"target": ["dmg", "zip"]
	},
	"linux": {
		"target": [
			{
				"target": "AppImage",
				"arch": ["x64"]
			}
		],
		"category": "Utility",
		"executableName": "Remota",
		"icon": "src/main/assets/icon.png"
	},
	"portable": {
		"artifactName": "Remota-${version}-portable.${ext}"
	},
	"appImage": {
		"artifactName": "Remota-${version}.${ext}"
	}
}
